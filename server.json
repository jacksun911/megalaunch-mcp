{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.jacksun911/megalaunch-mcp",
  "description": "AI-powered meme token launch service on Solana/pump.fun with bundled buys and Jito speed",
  "repository": {
    "url": "https://github.com/jacksun911/megalaunch-mcp",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "megalaunch-mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your MegaLaunch API key",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "MEGALAUNCH_API_KEY"
        }
      ]
    }
  ]
}
